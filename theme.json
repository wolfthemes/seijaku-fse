{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1000px",
			"wideSize": "1600px"
		},
		"color": {
			"palette": [
				{ "slug": "primary",       "color": "#000000 ",          "name": "Primary" },
				{ "slug": "primary-light", "color": "#f1f1f1",          "name": "Primary Light" },
				{ "slug": "secondary",     "color": "#14110e",          "name": "Secondary" },
				{ "slug": "accent",        "color": "#D3A043",          "name": "Accent" },
				{ "slug": "base",          "color": "#F5F5F7",          "name": "Base" },
				{ "slug": "base-2",        "color": "#ffffff",          "name": "Surface" },
				{ "slug": "contrast",      "color": "#1d1d1f",          "name": "Contrast" },
				{ "slug": "contrast-2",    "color": "#6b6b6b",          "name": "Muted" },
				{ "slug": "border",        "color": "rgba(0,0,0,0.10)",    "name": "Border" },
				{ "slug": "border-alt",    "color": "rgba(255,255,255,0.15)", "name": "Border Alt" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"name": "Heading",
					"slug": "heading",
					"fontFamily": "Urbanist, sans-serif"
				},
				{
					"name": "Body",
					"slug": "body",
					"fontFamily": "Rethink Sans, sans-serif"
				}
			],
			"fontSizes": [
				{ "slug": "xxs",     "name": "XXS",     "size": "0.6875rem","fluid": false },
				{ "slug": "xs",      "name": "XS",      "size": "0.75rem",   "fluid": { "min": "0.75rem",   "max": "0.8125rem" } },
				{ "slug": "sm",      "name": "SM",      "size": "0.875rem",  "fluid": { "min": "0.875rem",  "max": "0.9375rem" } },
				{ "slug": "base",    "name": "Base (body · h6 · 1rem)", "size": "1rem",      "fluid": { "min": "1rem",      "max": "1.0625rem" } },
				{ "slug": "md",      "name": "MD (h5 · ×1.25)",       "size": "1.25rem",   "fluid": { "min": "1.125rem",  "max": "1.25rem" } },
				{ "slug": "lg",      "name": "LG (h4 · ×1.5625)",     "size": "1.5625rem", "fluid": { "min": "1.375rem",  "max": "1.5625rem" } },
				{ "slug": "xl",      "name": "XL (h3 · ×1.953)",      "size": "1.953rem",  "fluid": { "min": "1.625rem",  "max": "1.953rem" } },
				{ "slug": "2-xl",    "name": "2XL (h2 · ×2.441)",     "size": "2.441rem",  "fluid": { "min": "1.953rem",  "max": "2.441rem" } },
				{ "slug": "3-xl",    "name": "3XL (h1 · ×3.052)",     "size": "3.052rem",  "fluid": { "min": "2.25rem",   "max": "3.052rem" } },
				{ "slug": "display", "name": "Display (page hero · ×3.815)", "size": "3.815rem",  "fluid": { "min": "2.625rem",  "max": "3.815rem" } },
				{ "slug": "hero",    "name": "Hero (cover · ×4.768)", "size": "4.768rem",  "fluid": { "min": "3rem",      "max": "4.768rem" } }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"customSpacingSize": true,
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingSizes": [
				{ "slug": "1",  "name": "1",  "size": "0.25rem" },
				{ "slug": "2",  "name": "2",  "size": "0.5rem" },
				{ "slug": "3",  "name": "3",  "size": "0.75rem" },
				{ "slug": "4",  "name": "4",  "size": "1rem" },
				{ "slug": "5",  "name": "5",  "size": "1.5rem" },
				{ "slug": "6",  "name": "6",  "size": "2rem" },
				{ "slug": "7",  "name": "7",  "size": "3rem" },
				{ "slug": "8",  "name": "8",  "size": "4rem" },
				{ "slug": "9",  "name": "9",  "size": "6rem" },
				{ "slug": "10", "name": "10", "size": "8rem" },
				{ "slug": "11", "name": "11 — Section", "size": "clamp(6rem, 10vw, 10rem)" },
				{ "slug": "12", "name": "12 — Section XL", "size": "clamp(8rem, 14vw, 14rem)" }
			]
		},
		"custom": {
			"wolf": {
				"radius-sm":        "2px",
				"radius-md":        "4px",
				"radius-lg":        "8px",
				"radius-pill":      "999px",
				"border-color":     "rgba(0, 0, 0, 0.10)",
				"border-width":     "1px",
				"btn-radius":       "999em",
				"btn-padding-x":    "1.75rem",
				"btn-padding-y":    "0.3rem",
				"btn-font-weight":  "600",
				"shadow-card":      "none",
				"transition-speed": "0.25s",
				"transition-ease":  "ease"
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" },
		{ "name": "header-overlay", "title": "Header Overlay", "area": "header" }
	],
	"styles": {
		"spacing": {
			"padding": {
				"top": "0",
				"bottom": "0",
				"left": "clamp(1rem, 2.5vw, 2.5rem)",
				"right": "clamp(1rem, 2.5vw, 2.5rem)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.55"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3-xl)",
					"lineHeight": "1.08",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2-xl)",
					"lineHeight": "1.15",
					"letterSpacing": "-0.018em"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"lineHeight": "1.2",
					"letterSpacing": "-0.015em"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)",
					"lineHeight": "1.3",
					"letterSpacing": "-0.011em"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--md)",
					"lineHeight": "1.35",
					"letterSpacing": "-0.008em"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--base)",
					"lineHeight": "1.45",
					"letterSpacing": "-0.005em"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": { "radius": "var(--wolf-btn-radius)" },
				"typography": {
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"letterSpacing": "-0.022em",
					"textTransform": "uppercase"
				},
				"spacing": {
					"padding": {
						"top": "var(--wolf-btn-padding-y)",
						"bottom": "var(--wolf-btn-padding-y)",
						"left": "var(--wolf-btn-padding-x)",
						"right": "var(--wolf-btn-padding-x)"
					}
				},
				":hover": {
					"color": { "background": "var(--wp--preset--color--primary-light)" }
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--xs)",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "-0.01em"
				}
			}
		}
	}
}
