{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1000px",
			"wideSize": "1600px"
		},
		"color": {
			"palette": [
				{ "slug": "primary",       "color": "#0c10ff",          "name": "Primary" },
				{ "slug": "primary-light", "color": "#0a0bd1",          "name": "Primary Light" },
				{ "slug": "secondary",     "color": "#111111",          "name": "Secondary" },
				{ "slug": "accent",        "color": "#0c10ff",          "name": "Accent" },
				{ "slug": "base",          "color": "#ffffff",          "name": "Base" },
				{ "slug": "base-2",        "color": "#f4f4f2",          "name": "Surface" },
				{ "slug": "contrast",      "color": "#141414",          "name": "Contrast" },
				{ "slug": "contrast-2",    "color": "#6b6b6b",          "name": "Muted" },
				{ "slug": "border",        "color": "rgba(0,0,0,0.10)", "name": "Border" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"name": "Heading",
					"slug": "heading",
					"fontFamily": "Lexend, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Lexend",
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"src": [ "https://fonts.gstatic.com/s/lexend/v24/wlpwgwvFAVdoq2_nSKkaSKluiKzjgg.woff2" ]
						}
					]
				},
				{
					"name": "Body",
					"slug": "body",
					"fontFamily": "Rethink Sans, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Rethink Sans",
							"fontStyle": "normal",
							"fontWeight": "400 600",
							"src": [ "https://fonts.gstatic.com/s/rethinksans/v4/AMOTz46as3KOnxFVgGYbAKh5-s66io.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "xxs",     "name": "XXS",     "size": "0.6875rem","fluid": false },
				{ "slug": "xs",      "name": "XS",      "size": "0.75rem",  "fluid": { "min": "0.75rem",  "max": "0.8125rem" } },
				{ "slug": "sm",      "name": "SM",      "size": "0.875rem", "fluid": { "min": "0.875rem", "max": "0.9375rem" } },
				{ "slug": "base",    "name": "Base",    "size": "1rem",     "fluid": { "min": "1rem",     "max": "1.125rem" } },
				{ "slug": "md",      "name": "MD",      "size": "1.25rem",  "fluid": { "min": "1.125rem", "max": "1.375rem" } },
				{ "slug": "lg",      "name": "LG",      "size": "1.5rem",   "fluid": { "min": "1.375rem", "max": "1.75rem" } },
				{ "slug": "xl",      "name": "XL",      "size": "2rem",     "fluid": { "min": "1.75rem",  "max": "2.5rem" } },
				{ "slug": "2xl",     "name": "2XL",     "size": "2.5rem",   "fluid": { "min": "2rem",     "max": "3rem" } },
				{ "slug": "3xl",     "name": "3XL",     "size": "3.25rem",  "fluid": { "min": "2.5rem",   "max": "4rem" } },
				{ "slug": "display", "name": "Display", "size": "4.25rem",  "fluid": { "min": "3rem",     "max": "5.25rem" } }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"customSpacingSize": true,
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingSizes": [
				{ "slug": "1",  "name": "1",  "size": "0.25rem" },
				{ "slug": "2",  "name": "2",  "size": "0.5rem" },
				{ "slug": "3",  "name": "3",  "size": "0.75rem" },
				{ "slug": "4",  "name": "4",  "size": "1rem" },
				{ "slug": "5",  "name": "5",  "size": "1.5rem" },
				{ "slug": "6",  "name": "6",  "size": "2rem" },
				{ "slug": "7",  "name": "7",  "size": "3rem" },
				{ "slug": "8",  "name": "8",  "size": "4rem" },
				{ "slug": "9",  "name": "9",  "size": "6rem" },
				{ "slug": "10", "name": "10", "size": "8rem" },
				{ "slug": "11", "name": "11 — Section", "size": "clamp(6rem, 10vw, 10rem)" },
				{ "slug": "12", "name": "12 — Section XL", "size": "clamp(8rem, 14vw, 14rem)" }
			]
		}
	},
	"custom": {
		"wolf": {
			"radius-sm":        "2px",
			"radius-md":        "4px",
			"radius-lg":        "8px",
			"radius-pill":      "999px",
			"border-color":     "rgba(0, 0, 0, 0.10)",
			"border-width":     "1px",
			"btn-radius":       "4px",
			"btn-padding-x":    "1.75rem",
			"btn-padding-y":    "0.9rem",
			"btn-font-weight":  "600",
			"shadow-card":      "none",
			"transition-speed": "0.25s",
			"transition-ease":  "ease"
		}
	},
	"styles": {
		"spacing": {
			"padding": {
				"top": "0",
				"bottom": "0",
				"left": "clamp(1rem, 2.5vw, 2.5rem)",
				"right": "clamp(1rem, 2.5vw, 2.5rem)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em",
					"textTransform": "uppercase"
				}
			},
			"h1": {
				"typography": {
					"lineHeight": "1.02",
					"letterSpacing": "-0.03em"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": { "radius": "var(--wolf-btn-radius)" },
				"typography": {
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"letterSpacing": "0.01em"
				},
				"spacing": {
					"padding": {
						"top": "0.9rem",
						"bottom": "0.9rem",
						"left": "1.75rem",
						"right": "1.75rem"
					}
				},
				":hover": {
					"color": { "background": "var(--wp--preset--color--primary-light)" }
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--xxs)",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "-0.01em"
				}
			}
		}
	}
}
