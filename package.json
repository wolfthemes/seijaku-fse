{
	"name": "seijaku-fse",
	"version": "1.0.0",
	"description": "WolfThemes.com FSE redesign — child theme of wolf-blank.",
	"author": "Constantin Saguin (WolfThemes)",
	"license": "GPL-2.0-or-later",
	"private": true,
	"keywords": [
		"wordpress",
		"theme",
		"fse",
		"block-theme",
		"wolfthemes"
	],
	"homepage": "https://wolfthemes.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wolfthemes/seijaku-fse.git"
	},
	"bugs": {
		"url": "https://github.com/wolfthemes/seijaku-fse/issues"
	},
	"engines": {
		"node": ">=20",
		"npm": ">=10"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0",
		"browser-sync": "^3.0.0",
		"browser-sync-webpack-plugin": "^2.3.0"
	},
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js \"src/scripts/**/*.js\" --no-error-on-unmatched-pattern",
		"format:js": "wp-scripts lint-js --fix",
		"lint:css": "wp-scripts lint-style \"src/styles/**/*.scss\"",
		"format:css": "stylelint \"**/*.scss\" --fix",
		"lint:md": "wp-scripts lint-md-docs",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"format": "wp-scripts format \"src/**/*.{js,scss}\"",
		"lint": "npm run lint:js && npm run lint:css && npm run lint:pkg-json",
		"lint:php": "./vendor/bin/phpcs --standard=phpcs.xml.dist -v",
		"format:php": "./vendor/bin/phpcbf --standard=phpcs.xml.dist -v || true",
		"packages-update": "wp-scripts packages-update"
	}
}
